@misc{yaoWaterScenesMultiTask4D2024,
  title = {{{WaterScenes}}: {{A Multi-Task 4D Radar-Camera Fusion Dataset}} and {{Benchmarks}} for {{Autonomous Driving}} on {{Water Surfaces}}},
