@article{bae_etal_FastPathSearching_2017,
  title = {{A Fast Path-Searching Algorithm for Omnidirectional Entities in 3D Environments Using Dimension Transform}},
  author = {Bae, Hyun-Soo and Lee, Sang-Hyun and Lee, Ji-Yeon and Lee, Suk-Gyu},
  year = 2017,
  month = oct,
  journal = {Journal of Institute of Control, Robotics and Systems},
  volume = {23},
  number = {10},
  pages = {879--885},
  issn = {1976-5622, 2233-4335},
  doi = {10.5302/J.ICROS.2017.17.0102},
  urldate = {2026-01-05},
  abstract = {In this paper, we propose a new 3-dimensional (3D) path planning algorithm for entity navigation. Because the use of Unmanned Aerial Vehicles (UAVs) and Unmanned Underwater Vehicles (UUVs) are becoming increasingly widespread, 3D path planning has been addressed by many researchers. The conventional path planning in 3D environments is extended by using an existing 2D path-searching algorithm. In this method, despite the wide search range and long search time, the optimal path is hardly obtained. The proposed algorithm generates two dimensional planes with a starting point and a target point, and transforms the generated plane space into a 3D path by generating a 2D path to transform the spatial information of the space in the 3D environment. Because the generated path produces a narrow range of 2D path generation, this method has better computation time than the existing algorithms to ensure the real-time generation of paths in 3D environments. The simulation results show that the proposed algorithm can efficiently search the path in 3D environments using the dimension transformation. As a result, the proposed algorithm is more suitable for the real-time navigation of robots than for searching the optimal path in a 3D environment.},
  langid = {korean},
  file = {C:\Users\kriso_\Desktop\Zotero\storage\B27YTMAU\Bae 등 - 2017 - A Fast Path-Searching Algorithm for Omnidirectional Entities in 3D Environments Using Dimension Tran.pdf}
}

